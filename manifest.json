{
  "manifest_version": 3,
  "name": "Twitch Rewind",
  "version": "1.0.0",
  "description": "Unlock stream rewind on any Twitch live channel",
  "permissions": ["storage"],
  "host_permissions": ["*://*.twitch.tv/*"],
  "content_scripts": [
    {
      "matches": ["*://*.twitch.tv/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/inject.js", "lib/hls.min.js"],
      "matches": ["*://*.twitch.tv/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
